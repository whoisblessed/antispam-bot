# Токен бота от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Режим действия при обнаружении спама:
#   delete       — удалить сообщение и заблокировать пользователя
#   notify_admin — отправить уведомление администратору
ACTION_MODE=delete

# Имя администратора без @ (для режима notify_admin)
ADMIN_USERNAME=admin

# Время на верификацию нового участника в секундах (по умолчанию 180 = 3 мин)
VERIFY_TIMEOUT=180

# ── LLM настройки ────────────────────────────────────────────────────────────

# Провайдер LLM:
#   openai     — OpenAI API  (GPT-4o-mini и др.)
#   deepseek   — DeepSeek API (openai-совместимый, меняйте LLM_BASE_URL)
#   anthropic  — Anthropic Claude API
LLM_PROVIDER=openai

# API-ключ для выбранного провайдера (выдаётся руководителем практики)
LLM_API_KEY=your_llm_api_key_here

# Базовый URL API
# OpenAI:   https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# Название модели
# OpenAI:   gpt-4o-mini
# DeepSeek: deepseek-chat
# Anthropic: claude-haiku-4-5-20251001
LLM_MODEL=gpt-4o-mini
